# BAC - Business Analysis Copilot
# Environment Configuration

# Flask
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# HOPEX Integration (optional - mock data used if not set)
HOPEX_API_URL=https://your-hopex-instance/graphql
HOPEX_API_KEY=your-hopex-api-key

# Pinecone (for RAG - optional for Phase 1)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-environment
PINECONE_INDEX=bac-templates
