# SACP Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DB_PASSWORD=localdev
DATABASE_URL=postgresql://sacp:localdev@localhost:5432/sacp

# Redis Configuration
REDIS_URL=redis://localhost:6379

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1024

# Pinecone Configuration
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=referencemodels

# HOPEX Configuration (optional, can be mocked)
MEGA_ENDPOINT=https://your-hopex-endpoint
HOPEX_API_KEY=your-hopex-api-key

# Azure Configuration (optional)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
